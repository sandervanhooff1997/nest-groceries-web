# -----------------------------------------------------------------------------
# Kinde (authentication)
# -----------------------------------------------------------------------------
# Client id + secret come from the "Backends for frontends (BFF) - server-side"
# application you create in the Kinde admin console. The Next.js app acts as a
# BFF: it exchanges the Kinde authorization code for tokens server-side and
# stores them in an encrypted cookie.
KINDE_CLIENT_ID=your-kinde-client-id
KINDE_CLIENT_SECRET=your-kinde-client-secret
KINDE_ISSUER_URL=https://your-tenant.kinde.com

# Where the app is served from (must match the allowed callback URLs on Kinde).
KINDE_SITE_URL=http://localhost:3001
KINDE_POST_LOGOUT_REDIRECT_URL=http://localhost:3001
KINDE_POST_LOGIN_REDIRECT_URL=http://localhost:3001/dashboard

# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------
# Base URL of the NestJS API, including the /api global prefix. The generated
# OpenAPI client (src/api/generated) reads this via the AuthProvider bridge and
# attaches the user's Kinde access token as a bearer token to every request.
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001
